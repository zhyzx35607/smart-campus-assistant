.tab-bar {
  display: flex;
  flex-direction: row;
  justify-content: space-around;
  align-items: center;
  height: 110rpx;
  padding-bottom: env(safe-area-inset-bottom);
  background: #ffffff;
  border-top: 1rpx solid #f1f5f9;
  position: fixed;
  bottom: 0;
  left: 0;
  right: 0;
  z-index: 999;
  box-sizing: content-box;
}

.tab-item {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  flex: 1;
  padding: 8rpx 0;
  min-width: 0;
}

.tab-icon-wrap {
  width: 52rpx;
  height: 52rpx;
  display: flex;
  justify-content: center;
  align-items: center;
  margin-bottom: 4rpx;
}

.tab-icon-text {
  font-size: 44rpx;
  color: #94a3b8;
}

.tab-item.active .tab-icon-text {
  color: #2563eb;
}

.tab-text {
  font-size: 20rpx;
  color: #94a3b8;
  margin-top: 2rpx;
  white-space: nowrap;
}

.tab-item.active .tab-text {
  color: #2563eb;
  font-weight: 600;
}
