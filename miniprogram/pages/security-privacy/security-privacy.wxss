.page {
  padding: 24rpx 32rpx;
  background: #f1f5f9;
  padding-bottom: calc(60rpx + env(safe-area-inset-bottom));
}

.card {
  background: #ffffff;
  border-radius: 32rpx;
  padding: 32rpx;
  margin-bottom: 24rpx;
  box-shadow: 0 2rpx 8rpx rgba(0, 0, 0, 0.04);
  overflow: hidden;
}

.card-title {
  font-size: 32rpx;
  font-weight: 700;
  color: #0f172a;
  margin-bottom: 24rpx;
}

.card-hint {
  font-size: 22rpx;
  color: #94a3b8;
  display: block;
  margin-top: 20rpx;
  padding-top: 20rpx;
  border-top: 1rpx solid #f8fafc;
  line-height: 1.5;
}

.form-list {
  display: flex;
  flex-direction: column;
}

.form-item {
  margin-bottom: 20rpx;
}

.form-label {
  font-size: 26rpx;
  font-weight: 500;
  color: #475569;
  margin-bottom: 8rpx;
  display: block;
}

/* Switch items */
.switch-item {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 24rpx 0;
  border-bottom: 1rpx solid #f8fafc;
}

.switch-item:last-of-type {
  border-bottom: none;
}

.switch-left {
  display: flex;
  align-items: center;
  gap: 16rpx;
  flex: 1;
  margin-right: 16rpx;
  min-width: 0;
}

.switch-icon {
  width: 72rpx;
  height: 72rpx;
  border-radius: 16rpx;
  display: flex;
  justify-content: center;
  align-items: center;
  font-size: 36rpx;
  flex-shrink: 0;
}

.switch-icon.purple { background: #f3e8ff; }
.switch-icon.amber { background: #ffedd5; }
.switch-icon.green { background: #dcfce7; }
.switch-icon.blue { background: #dbeafe; }
.switch-icon.gray { background: #f1f5f9; }
.switch-icon.red { background: #fee2e2; }

.switch-info {
  display: flex;
  flex-direction: column;
  min-width: 0;
}

.switch-name {
  font-size: 28rpx;
  font-weight: 500;
  color: #1e293b;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}

.switch-desc {
  font-size: 22rpx;
  color: #94a3b8;
  margin-top: 4rpx;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}

.picker-btn {
  padding: 16rpx 24rpx;
  border: 2rpx solid #e2e8f0;
  border-radius: 16rpx;
  font-size: 24rpx;
  color: #475569;
  background: #ffffff;
  flex-shrink: 0;
  white-space: nowrap;
}

.action-btn {
  padding: 16rpx 24rpx;
  border: 2rpx solid #e2e8f0;
  border-radius: 16rpx;
  font-size: 24rpx;
  color: #475569;
  background: #ffffff;
  flex-shrink: 0;
  white-space: nowrap;
}

.action-btn.danger {
  border-color: #fecaca;
  color: #dc2626;
  background: #fef2f2;
}

/* 操作按钮 */
.action-row {
  display: flex;
  gap: 16rpx;
  margin-bottom: 24rpx;
}

.btn-cancel {
  background: #ffffff;
  border: 2rpx solid #e2e8f0;
  padding: 20rpx 32rpx;
  border-radius: 20rpx;
  font-size: 26rpx;
  color: #475569;
  font-weight: 500;
  white-space: nowrap;
}

.btn-reset {
  background: #ffffff;
  border: 2rpx solid #e2e8f0;
  padding: 20rpx 32rpx;
  border-radius: 20rpx;
  font-size: 26rpx;
  color: #475569;
  font-weight: 500;
  white-space: nowrap;
}

.btn-primary {
  flex: 1;
  background: linear-gradient(135deg, #2563eb, #4338ca);
  padding: 20rpx 32rpx;
  border-radius: 20rpx;
  font-size: 26rpx;
  color: #ffffff;
  font-weight: 700;
  text-align: center;
}

.notice-card {
  background: #eff6ff;
  border: 1rpx solid #bfdbfe;
  border-radius: 24rpx;
  padding: 24rpx;
}

.notice-title {
  font-size: 28rpx;
  font-weight: 700;
  color: #1e40af;
  display: block;
  margin-bottom: 8rpx;
}

.notice-item {
  font-size: 24rpx;
  color: #1e40af;
  display: block;
  line-height: 1.8;
}
