.page {
  padding-bottom: 140rpx;
  background: #f1f5f9;
}

/* 用户信息卡片 */
.user-card {
  background: linear-gradient(135deg, #2563eb, #4338ca);
  padding: 32rpx;
}

.user-info {
  display: flex;
  align-items: center;
  gap: 20rpx;
}

.user-avatar {
  width: 120rpx;
  height: 120rpx;
  border-radius: 50%;
  border: 6rpx solid rgba(255, 255, 255, 0.3);
  flex-shrink: 0;
}

.user-detail {
  flex: 1;
  display: flex;
  flex-direction: column;
  min-width: 0;
}

.user-name {
  font-size: 40rpx;
  font-weight: 700;
  color: #ffffff;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}

.user-id {
  font-size: 24rpx;
  color: rgba(255, 255, 255, 0.8);
}

.user-college {
  font-size: 24rpx;
  color: rgba(255, 255, 255, 0.7);
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}

.edit-btn {
  background: rgba(255, 255, 255, 0.2);
  padding: 12rpx 24rpx;
  border-radius: 16rpx;
  font-size: 24rpx;
  color: #ffffff;
  white-space: nowrap;
  flex-shrink: 0;
}

/* 统计卡片 */
.stats-row {
  display: flex;
  gap: 16rpx;
  padding: 24rpx 32rpx;
}

.stat-card {
  flex: 1;
  background: #ffffff;
  padding: 24rpx;
  border-radius: 24rpx;
  text-align: center;
  box-shadow: 0 2rpx 8rpx rgba(0, 0, 0, 0.04);
}

.stat-icon {
  font-size: 36rpx;
  display: block;
  margin-bottom: 8rpx;
}

.stat-num {
  font-size: 40rpx;
  font-weight: 700;
  color: #0f172a;
  display: block;
}

.stat-label {
  font-size: 22rpx;
  color: #94a3b8;
  display: block;
}

/* 标签页 */
.tab-section {
  margin: 0 32rpx;
  background: #ffffff;
  border-radius: 32rpx;
  overflow: hidden;
  box-shadow: 0 2rpx 8rpx rgba(0, 0, 0, 0.04);
}

.tab-header {
  display: flex;
  border-bottom: 1rpx solid #f1f5f9;
}

.tab-btn {
  flex: 1;
  text-align: center;
  padding: 24rpx 0;
  font-size: 26rpx;
  font-weight: 500;
  color: #64748b;
  border-bottom: 4rpx solid transparent;
  white-space: nowrap;
}

.tab-btn.active {
  color: #2563eb;
  border-bottom-color: #2563eb;
  font-weight: 600;
}

.tab-content {
  padding: 8rpx 0;
}

/* 问答历史 */
.qa-item {
  padding: 24rpx 28rpx;
  border-bottom: 1rpx solid #f8fafc;
}

.qa-top {
  display: flex;
  justify-content: space-between;
  align-items: flex-start;
}

.qa-left {
  flex: 1;
  margin-right: 16rpx;
  min-width: 0;
}

.qa-date {
  font-size: 22rpx;
  color: #94a3b8;
  display: block;
  margin-bottom: 4rpx;
}

.qa-question {
  font-size: 28rpx;
  font-weight: 500;
  color: #1e293b;
  display: block;
  margin-bottom: 4rpx;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}

.qa-answer {
  font-size: 24rpx;
  color: #64748b;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}

.qa-actions {
  display: flex;
  gap: 24rpx;
  margin-top: 12rpx;
}

.qa-action {
  font-size: 22rpx;
  color: #94a3b8;
}

/* 我的帖子 */
.my-post-item {
  padding: 24rpx 28rpx;
  border-bottom: 1rpx solid #f8fafc;
}

.my-post-top {
  display: flex;
  justify-content: space-between;
  margin-bottom: 8rpx;
  gap: 16rpx;
}

.my-post-title {
  font-size: 28rpx;
  font-weight: 500;
  color: #1e293b;
  flex: 1;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}

.my-post-date {
  font-size: 22rpx;
  color: #94a3b8;
  flex-shrink: 0;
}

.my-post-desc {
  font-size: 24rpx;
  color: #64748b;
  display: block;
  margin-bottom: 8rpx;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}

.my-post-stats {
  display: flex;
  gap: 24rpx;
}

.my-post-stats .stat {
  font-size: 22rpx;
  color: #94a3b8;
}

/* 反馈记录 */
.feedback-item {
  padding: 24rpx 28rpx;
  border-bottom: 1rpx solid #f8fafc;
}

.feedback-top {
  display: flex;
  justify-content: space-between;
  align-items: flex-start;
}

.feedback-left {
  flex: 1;
  margin-right: 16rpx;
  min-width: 0;
}

.feedback-title {
  font-size: 28rpx;
  font-weight: 500;
  color: #1e293b;
  display: block;
  margin-bottom: 4rpx;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}

.feedback-desc {
  font-size: 24rpx;
  color: #64748b;
  display: block;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}

.feedback-result {
  font-size: 22rpx;
  color: #94a3b8;
  margin-top: 8rpx;
  display: block;
}

/* 设置列表 */
.settings-card {
  margin: 24rpx 32rpx;
  background: #ffffff;
  border-radius: 32rpx;
  overflow: hidden;
  box-shadow: 0 2rpx 8rpx rgba(0, 0, 0, 0.04);
}

.setting-item {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 28rpx;
  border-bottom: 1rpx solid #f8fafc;
}

.setting-item:last-child {
  border-bottom: none;
}

.setting-left {
  display: flex;
  align-items: center;
  gap: 16rpx;
  min-width: 0;
}

.setting-icon {
  font-size: 36rpx;
  flex-shrink: 0;
}

.setting-label {
  font-size: 28rpx;
  color: #1e293b;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}

.setting-arrow {
  font-size: 36rpx;
  color: #94a3b8;
  flex-shrink: 0;
}

.logout .setting-label {
  color: #ef4444;
}

.logout .setting-icon {
  opacity: 1;
}

/* ====== 用户兴趣画像 ====== */
.interest-section {
  margin: 0 32rpx 24rpx;
  background: #ffffff;
  border-radius: 32rpx;
  padding: 28rpx;
  box-shadow: 0 2rpx 8rpx rgba(0, 0, 0, 0.04);
}

.section-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 20rpx;
}

.section-title-inline {
  display: flex;
  align-items: center;
  gap: 8rpx;
}

.section-icon-text {
  font-size: 32rpx;
}

.section-title-label {
  font-size: 28rpx;
  font-weight: 700;
  color: #0f172a;
}

.tag-count {
  font-size: 22rpx;
  color: #64748b;
  background: #f1f5f9;
  padding: 4rpx 16rpx;
  border-radius: 12rpx;
  flex-shrink: 0;
}

.tags-container {
  display: flex;
  flex-wrap: wrap;
  gap: 16rpx;
  margin-bottom: 12rpx;
}

.interest-tag {
  display: flex;
  align-items: center;
  gap: 10rpx;
  padding: 14rpx 24rpx;
  background: #f8fafc;
  border: 2rpx solid #e2e8f0;
  border-radius: 20rpx;
  transition: all 0.2s ease;
}

.top-tag {
  background: linear-gradient(135deg, #eff6ff, #dbeafe);
  border-color: #93c5fd;
}

.tag-name {
  font-size: 26rpx;
  font-weight: 600;
  color: #334155;
}

.top-tag .tag-name {
  color: #1d4ed8;
}

.tag-count-badge {
  font-size: 20rpx;
  color: #94a3b8;
  background: #ffffff;
  padding: 2rpx 12rpx;
  border-radius: 10rpx;
}

.interest-hint {
  display: block;
  font-size: 22rpx;
  color: #94a3b8;
  line-height: 1.5;
  padding-top: 12rpx;
  border-top: 1rpx dashed #e2e8f0;
}

/* 空状态 */
.empty-interest {
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 40rpx 20rpx;
}

.empty-icon {
  font-size: 80rpx;
  margin-bottom: 16rpx;
}

.empty-text {
  font-size: 30rpx;
  font-weight: 600;
  color: #475569;
  display: block;
  margin-bottom: 8rpx;
}

.empty-sub {
  font-size: 24rpx;
  color: #94a3b8;
  text-align: center;
  display: block;
  margin-bottom: 24rpx;
  line-height: 1.5;
}

.go-chat-btn {
  background: #2563eb;
  color: #ffffff;
  padding: 18rpx 48rpx;
  border-radius: 24rpx;
  font-size: 26rpx;
  font-weight: 600;
}

.go-chat-btn:active {
  opacity: 0.85;
}
