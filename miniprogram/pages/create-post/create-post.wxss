.page {
  padding: 24rpx 32rpx 40rpx;
  background: #f8fafc;
  padding-bottom: calc(40rpx + env(safe-area-inset-bottom));
}

.form-section {
  background: #ffffff;
  border-radius: 32rpx;
  padding: 32rpx;
  margin-bottom: 24rpx;
  border: 1rpx solid #f1f5f9;
  overflow: hidden;
}

.form-group {
  margin-bottom: 32rpx;
}

.form-group:last-child {
  margin-bottom: 0;
}

.form-label {
  font-size: 28rpx;
  font-weight: 500;
  color: #475569;
  margin-bottom: 12rpx;
  display: block;
}

.required {
  color: #ef4444;
}

.input-field {
  width: 100%;
  padding: 24rpx;
  border: 2rpx solid #cbd5e1;
  border-radius: 20rpx;
  font-size: 28rpx;
  color: #1e293b;
  background: #ffffff;
  box-sizing: border-box;
}

.textarea-field {
  width: 100%;
  padding: 24rpx;
  border: 2rpx solid #cbd5e1;
  border-radius: 20rpx;
  font-size: 28rpx;
  color: #1e293b;
  background: #ffffff;
  box-sizing: border-box;
  line-height: 1.6;
}

.char-count {
  font-size: 22rpx;
  color: #94a3b8;
  text-align: right;
  display: block;
  margin-top: 8rpx;
}

.textarea-footer {
  display: flex;
  justify-content: space-between;
  margin-top: 8rpx;
  gap: 16rpx;
}

.hint-text {
  font-size: 22rpx;
  color: #94a3b8;
  flex: 1;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}

/* 标签 */
.tag-list {
  display: flex;
  flex-wrap: wrap;
  gap: 16rpx;
}

.tag-option {
  padding: 12rpx 28rpx;
  border-radius: 24rpx;
  font-size: 26rpx;
  border: 2rpx solid;
}

.tag-option.selected {
  font-weight: 600;
}

.tag-share { background: #fff7ed; border-color: #fed7aa; color: #ea580c; }
.tag-share.selected { background: #ffedd5; border-color: #f97316; }
.tag-hot { background: #fef2f2; border-color: #fecaca; color: #dc2626; }
.tag-hot.selected { background: #fee2e2; border-color: #ef4444; }
.tag-team { background: #eff6ff; border-color: #bfdbfe; color: #2563eb; }
.tag-team.selected { background: #dbeafe; border-color: #3b82f6; }
.tag-official { background: #f0fdf4; border-color: #bbf7d0; color: #16a34a; }
.tag-official.selected { background: #dcfce7; border-color: #22c55e; }
.tag-academic { background: #faf5ff; border-color: #e9d5ff; color: #9333ea; }
.tag-academic.selected { background: #f3e8ff; border-color: #a855f7; }
.tag-help { background: #fefce8; border-color: #fde68a; color: #a16207; }
.tag-help.selected { background: #fef9c3; border-color: #eab308; }

/* 选项 */
.options-list {
  display: flex;
  flex-direction: column;
}

.option-item {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 16rpx 0;
  border-bottom: 1rpx solid #f8fafc;
}

.option-item:last-child {
  border-bottom: none;
}

.option-text {
  font-size: 28rpx;
  color: #475569;
}

/* 上传区域 */
.upload-area {
  border: 4rpx dashed #e2e8f0;
  border-radius: 24rpx;
  padding: 48rpx 32rpx;
  text-align: center;
  background: #fafafa;
}

.upload-icon {
  font-size: 64rpx;
  display: block;
  margin-bottom: 12rpx;
}

.upload-text {
  font-size: 28rpx;
  color: #475569;
  display: block;
}

.upload-hint {
  font-size: 22rpx;
  color: #94a3b8;
  display: block;
  margin-top: 8rpx;
}

.file-list {
  margin-top: 16rpx;
}

.file-item {
  display: flex;
  align-items: center;
  padding: 16rpx;
  background: #f8fafc;
  border-radius: 16rpx;
  margin-bottom: 8rpx;
  overflow: hidden;
}

.file-icon {
  font-size: 32rpx;
  margin-right: 12rpx;
  flex-shrink: 0;
}

.file-info {
  flex: 1;
  min-width: 0;
}

.file-name {
  font-size: 26rpx;
  font-weight: 500;
  display: block;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}

.file-size {
  font-size: 22rpx;
  color: #94a3b8;
}

.file-remove {
  font-size: 28rpx;
  color: #94a3b8;
  padding: 8rpx;
  flex-shrink: 0;
}

/* 操作按钮 */
.action-bar {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 24rpx;
  flex-wrap: wrap;
  gap: 16rpx;
}

.action-left {
  display: flex;
}

.action-right {
  display: flex;
  gap: 16rpx;
}

.btn-draft {
  background: #ffffff;
  border: 2rpx solid #e2e8f0;
  padding: 20rpx 32rpx;
  border-radius: 20rpx;
  font-size: 26rpx;
  color: #475569;
  font-weight: 500;
  white-space: nowrap;
}

.btn-preview {
  background: #ffffff;
  border: 2rpx solid #e2e8f0;
  padding: 20rpx 32rpx;
  border-radius: 20rpx;
  font-size: 26rpx;
  color: #475569;
  font-weight: 500;
  white-space: nowrap;
}

.btn-cancel {
  background: #ffffff;
  border: 2rpx solid #e2e8f0;
  padding: 20rpx 32rpx;
  border-radius: 20rpx;
  font-size: 26rpx;
  color: #475569;
  font-weight: 500;
  white-space: nowrap;
}

.btn-submit {
  background: linear-gradient(135deg, #2563eb, #4338ca);
  padding: 20rpx 40rpx;
  border-radius: 20rpx;
  font-size: 26rpx;
  color: #ffffff;
  font-weight: 700;
  white-space: nowrap;
}

/* 发布须知 */
.notice-card {
  background: #eff6ff;
  border: 1rpx solid #bfdbfe;
  border-radius: 24rpx;
  padding: 24rpx;
}

.notice-title {
  font-size: 28rpx;
  font-weight: 700;
  color: #1e40af;
  display: block;
  margin-bottom: 8rpx;
}

.notice-item {
  font-size: 24rpx;
  color: #1e40af;
  display: block;
  line-height: 1.8;
}
