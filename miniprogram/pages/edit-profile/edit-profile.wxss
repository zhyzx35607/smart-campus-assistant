.page {
  padding: 24rpx 32rpx;
  background: #f1f5f9;
  padding-bottom: calc(60rpx + env(safe-area-inset-bottom));
}

.card {
  background: #ffffff;
  border-radius: 32rpx;
  padding: 32rpx;
  margin-bottom: 24rpx;
  box-shadow: 0 2rpx 8rpx rgba(0, 0, 0, 0.04);
  overflow: hidden;
}

.card-title {
  font-size: 32rpx;
  font-weight: 700;
  color: #0f172a;
  margin-bottom: 24rpx;
}

/* 头像 */
.avatar-section {
  display: flex;
  gap: 24rpx;
  align-items: flex-start;
}

.avatar-preview {
  width: 160rpx;
  height: 160rpx;
  border-radius: 50%;
  border: 6rpx solid #f1f5f9;
  flex-shrink: 0;
}

.avatar-actions {
  flex: 1;
  min-width: 0;
}

.avatar-hint {
  font-size: 24rpx;
  color: #64748b;
  display: block;
  margin-bottom: 16rpx;
  line-height: 1.5;
}

.avatar-btns {
  display: flex;
  gap: 16rpx;
  flex-wrap: wrap;
}

/* 表单 */
.form-list {
  display: flex;
  flex-direction: column;
}

.form-item {
  margin-bottom: 28rpx;
}

.form-label {
  font-size: 28rpx;
  font-weight: 600;
  color: #334155;
  margin-bottom: 12rpx;
  display: block;
}

.required {
  color: #ef4444;
}

.field-hint {
  font-size: 24rpx;
  color: #94a3b8;
  display: block;
  margin-top: 8rpx;
  line-height: 1.4;
}

.readonly {
  background: #f1f5f9;
  color: #64748b;
}

/* ===== 统一输入框（文本输入） ===== */
.input-field {
  width: 100%;
  height: 88rpx;
  padding: 0 28rpx;
  border: 2rpx solid #cbd5e1;
  border-radius: 16rpx;
  font-size: 30rpx;
  color: #1e293b;
  background: #ffffff;
  box-sizing: border-box;
  line-height: 88rpx;
}

.input-field:focus {
  border-color: #2563eb;
  box-shadow: 0 0 0 4rpx rgba(37, 99, 235, 0.1);
}

/* ===== 选择器（picker - 与输入框区分开） ===== */
.picker-field {
  height: 88rpx;
  padding: 0 28rpx;
  border: 2rpx solid #cbd5e1;
  border-radius: 16rpx;
  font-size: 30rpx;
  color: #1e293b;
  background: linear-gradient(135deg, #f8fafc, #f1f5f9);
  display: flex;
  align-items: center;
  justify-content: space-between;
  position: relative;
}

.picker-arrow {
  font-size: 28rpx;
  color: #64748b;
  flex-shrink: 0;
  margin-left: 12rpx;
}

.textarea-field {
  width: 100%;
  padding: 24rpx 28rpx;
  border: 2rpx solid #cbd5e1;
  border-radius: 16rpx;
  font-size: 30rpx;
  color: #1e293b;
  background: #ffffff;
  box-sizing: border-box;
  line-height: 1.7;
  min-height: 220rpx;
}

.textarea-field:focus {
  border-color: #2563eb;
  box-shadow: 0 0 0 4rpx rgba(37, 99, 235, 0.1);
}

/* 性别 */
.gender-row {
  display: flex;
  flex-wrap: wrap;
  gap: 16rpx;
}

.gender-btn {
  padding: 20rpx 32rpx;
  border-radius: 16rpx;
  font-size: 28rpx;
  background: #f1f5f9;
  color: #475569;
  border: 2rpx solid #e2e8f0;
  white-space: nowrap;
  min-height: 72rpx;
  display: flex;
  align-items: center;
  justify-content: center;
}

.gender-btn.active {
  background: #dbeafe;
  color: #2563eb;
  border-color: #93c5fd;
}

.gender-btn.pink.active {
  background: #fce7f3;
  color: #ec4899;
  border-color: #f9a8d4;
}

.gender-btn.purple.active {
  background: #f3e8ff;
  color: #9333ea;
  border-color: #d8b4fe;
}

.gender-btn.gray.active {
  background: #e2e8f0;
  color: #475569;
  border-color: #cbd5e1;
}

.char-count {
  font-size: 22rpx;
  color: #94a3b8;
  text-align: right;
  display: block;
  margin-top: 8rpx;
}

/* 操作按钮 */
.action-row {
  display: flex;
  gap: 16rpx;
  margin-bottom: 24rpx;
  flex-wrap: wrap;
}

.btn-cancel {
  background: #ffffff;
  border: 2rpx solid #e2e8f0;
  padding: 20rpx 32rpx;
  border-radius: 20rpx;
  font-size: 26rpx;
  color: #475569;
  text-align: center;
  font-weight: 500;
  white-space: nowrap;
}

.btn-reset {
  background: #ffffff;
  border: 2rpx solid #e2e8f0;
  padding: 20rpx 32rpx;
  border-radius: 20rpx;
  font-size: 26rpx;
  color: #475569;
  text-align: center;
  font-weight: 500;
  white-space: nowrap;
}

.btn-primary {
  flex: 1;
  background: linear-gradient(135deg, #2563eb, #4338ca);
  padding: 20rpx 32rpx;
  border-radius: 20rpx;
  font-size: 26rpx;
  color: #ffffff;
  text-align: center;
  font-weight: 700;
  min-width: 200rpx;
}

/* 提示 */
.notice-card {
  background: #eff6ff;
  border: 1rpx solid #bfdbfe;
  border-radius: 24rpx;
  padding: 24rpx;
}

.notice-title {
  font-size: 28rpx;
  font-weight: 700;
  color: #1e40af;
  display: block;
  margin-bottom: 8rpx;
}

.notice-item {
  font-size: 24rpx;
  color: #1e40af;
  display: block;
  line-height: 1.8;
}

/* ===== 自定义 Picker 弹窗 ===== */
.picker-popup-mask {
  position: fixed;
  top: 0; left: 0; right: 0; bottom: 0;
  background: rgba(0, 0, 0, 0.5);
  z-index: 999;
  opacity: 0;
  pointer-events: none;
  transition: opacity 0.25s ease;
}

.picker-popup-mask.show {
  opacity: 1;
  pointer-events: auto;
}

.picker-popup {
  position: fixed;
  left: 0; right: 0; bottom: 0;
  background: #ffffff;
  border-radius: 32rpx 32rpx 0 0;
  z-index: 1000;
  transform: translateY(100%);
  transition: transform 0.3s ease;
  box-shadow: 0 -8rpx 32rpx rgba(0, 0, 0, 0.12);
}

.picker-popup.show {
  transform: translateY(0);
}

.picker-popup-header {
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 28rpx 32rpx;
  border-bottom: 1rpx solid #f1f5f9;
}

.picker-popup-cancel {
  font-size: 30rpx;
  color: #94a3b8;
  padding: 8rpx 16rpx;
}

.picker-popup-title {
  font-size: 32rpx;
  font-weight: 600;
  color: #1e293b;
}

.picker-popup-confirm {
  font-size: 30rpx;
  color: #2563eb;
  font-weight: 600;
  padding: 8rpx 16rpx;
}

.picker-popup-view {
  height: 480rpx;
}

.picker-popup-item {
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 34rpx;
  color: #334155;
  padding: 0 16rpx;
}
