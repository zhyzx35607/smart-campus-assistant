<view class="page">
  <!-- 头像 -->
  <view class="card">
    <view class="card-title">👤 个人头像</view>
    <view class="avatar-section">
      <image class="avatar-preview" src="{{avatarUrl}}" mode="aspectFill" />
      <view class="avatar-actions">
        <text class="avatar-hint">支持 JPG、PNG 格式，大小不超过 2MB</text>
        <view class="avatar-btns">
          <view class="btn-outline" bindtap="onUploadAvatar">📤 上传新头像</view>
          <view class="btn-outline" bindtap="onDefaultAvatar">使用默认头像</view>
        </view>
      </view>
    </view>
  </view>

  <!-- 基本信息 -->
  <view class="card">
    <view class="card-title">📋 基本信息</view>
    <view class="form-list">
      <view class="form-item">
        <text class="form-label">姓名 <text class="required">*</text></text>
        <input class="input-field" value="{{formData.fullname}}" bindinput="onFullnameInput" placeholder="请输入真实姓名" />
      </view>
      <view class="form-item">
        <text class="form-label">学号</text>
        <input class="input-field readonly" value="{{formData.studentId}}" readonly />
        <text class="field-hint">学号不可修改</text>
      </view>
      <view class="form-item">
        <text class="form-label">学院</text>
        <view class="picker-field" bindtap="showPicker" data-type="college">
          <text>{{colleges[collegeIndex]}}</text>
          <text class="picker-arrow">▾</text>
        </view>
      </view>
      <view class="form-item">
        <text class="form-label">年级</text>
        <view class="picker-field" bindtap="showPicker" data-type="grade">
          <text>{{grades[gradeIndex]}}</text>
          <text class="picker-arrow">▾</text>
        </view>
      </view>
      <view class="form-item">
        <text class="form-label">邮箱地址</text>
        <input class="input-field" value="{{formData.email}}" bindinput="onEmailInput" placeholder="请输入常用邮箱" />
      </view>
      <view class="form-item">
        <text class="form-label">手机号码</text>
        <input class="input-field" type="number" value="{{formData.phone}}" bindinput="onPhoneInput" placeholder="请输入手机号码" maxlength="11" />
      </view>
      <view class="form-item">
        <text class="form-label">性别</text>
        <view class="gender-row">
          <view class="gender-btn {{formData.gender === 'male' ? 'active' : ''}}" data-value="male" bindtap="onGenderChange">男</view>
          <view class="gender-btn {{formData.gender === 'female' ? 'active pink' : ''}}" data-value="female" bindtap="onGenderChange">女</view>
          <view class="gender-btn {{formData.gender === 'other' ? 'active purple' : ''}}" data-value="other" bindtap="onGenderChange">其他</view>
          <view class="gender-btn {{formData.gender === 'secret' ? 'active gray' : ''}}" data-value="secret" bindtap="onGenderChange">不愿透露</view>
        </view>
      </view>
      <view class="form-item">
        <text class="form-label">家乡省份</text>
        <view class="picker-field" bindtap="showPicker" data-type="province">
          <text>{{provinces[provinceIndex] || '请选择省份'}}</text>
          <text class="picker-arrow">▾</text>
        </view>
      </view>
      <view class="form-item">
        <text class="form-label">详细家乡信息（可选）</text>
        <input class="input-field" value="{{formData.hometown}}" bindinput="onHometownInput" placeholder="例如：杭州市西湖区、宁波市鄞州区等" />
        <text class="field-hint">填写城市或具体地区，方便寻找同乡</text>
      </view>
    </view>
  </view>

  <!-- 个人简介 -->
  <view class="card">
    <view class="card-title">📝 个人简介</view>
    <textarea class="textarea-field" value="{{formData.bio}}" bindinput="onBioInput" placeholder="介绍一下自己..." maxlength="200" auto-height style="min-height: 160rpx;" />
    <text class="char-count">{{bioLength}}/200</text>
  </view>

  <!-- 操作按钮 -->
  <view class="action-row">
    <view class="btn-cancel" bindtap="onCancel">取消</view>
    <view class="btn-reset" bindtap="onReset">重置</view>
    <view class="btn-primary" bindtap="onSave">✅ 保存更改</view>
  </view>

  <!-- 提示 -->
  <view class="notice-card">
    <text class="notice-title">💡 温馨提示：</text>
    <text class="notice-item">· 个人信息更新后，可能需要重新登录才能生效</text>
    <text class="notice-item">· 请确保填写的信息真实有效</text>
    <text class="notice-item">· 个人简介将公开显示在您的个人主页上</text>
    <text class="notice-item">· 学号是重要身份标识，一旦设置无法修改</text>
  </view>

  <!-- 自定义选择器弹窗 -->
  <view class="picker-popup-mask {{showPickerPopup ? 'show' : ''}}" bindtap="hidePicker"></view>
  <view class="picker-popup {{showPickerPopup ? 'show' : ''}}">
    <view class="picker-popup-header">
      <text class="picker-popup-cancel" bindtap="hidePicker">取消</text>
      <text class="picker-popup-title">{{pickerTitle}}</text>
      <text class="picker-popup-confirm" bindtap="confirmPicker">确定</text>
    </view>
    <picker-view class="picker-popup-view" value="{{pickerValue}}" bindchange="onPickerChange">
      <picker-view-column>
        <view wx:for="{{pickerRange}}" wx:key="*this" class="picker-popup-item">{{item}}</view>
      </picker-view-column>
    </picker-view>
  </view>
</view>
