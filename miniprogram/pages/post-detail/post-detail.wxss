.page {
  padding: 24rpx 32rpx 160rpx;
  background: #f8fafc;
}

.post-card {
  background: #ffffff;
  border-radius: 32rpx;
  padding: 32rpx;
  margin-bottom: 24rpx;
  box-shadow: 0 2rpx 12rpx rgba(0, 0, 0, 0.04);
  overflow: hidden;
}

.post-header {
  display: flex;
  align-items: center;
  margin-bottom: 20rpx;
}

.post-avatar {
  width: 88rpx;
  height: 88rpx;
  border-radius: 50%;
  margin-right: 16rpx;
  flex-shrink: 0;
}

.post-author-info {
  flex: 1;
  min-width: 0;
}

.post-author {
  font-size: 30rpx;
  font-weight: 700;
  color: #1e293b;
  display: block;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}

.post-meta {
  display: flex;
  align-items: center;
  gap: 12rpx;
  margin-top: 4rpx;
}

.post-time {
  font-size: 22rpx;
  color: #94a3b8;
}

.post-title {
  font-size: 34rpx;
  font-weight: 700;
  color: #0f172a;
  display: block;
  margin-bottom: 16rpx;
  word-break: break-word;
}

.post-content {
  font-size: 28rpx;
  color: #475569;
  line-height: 1.7;
  display: block;
  word-break: break-all;
}

.post-actions {
  display: flex;
  gap: 40rpx;
  padding-top: 24rpx;
  margin-top: 24rpx;
  border-top: 1rpx solid #f1f5f9;
}

.action-btn {
  display: flex;
  align-items: center;
  gap: 8rpx;
  font-size: 26rpx;
  color: #64748b;
  flex-shrink: 0;
}

.action-num {
  font-size: 26rpx;
}

.liked .action-num {
  color: #ef4444;
}

.bookmarked .action-num {
  color: #2563eb;
}

/* 官方回应 */
.official-card {
  background: #f0fdf4;
  border-radius: 32rpx;
  padding: 24rpx;
  margin-bottom: 24rpx;
  border-left: 8rpx solid #22c55e;
  overflow: hidden;
}

.official-header {
  display: flex;
  align-items: center;
  gap: 8rpx;
  margin-bottom: 12rpx;
}

.official-icon {
  font-size: 32rpx;
}

.official-title {
  font-size: 28rpx;
  font-weight: 700;
  color: #15803d;
}

.official-content {
  font-size: 26rpx;
  color: #16a34a;
  line-height: 1.6;
  word-break: break-all;
}

/* 评论区 */
.comment-section {
  background: #ffffff;
  border-radius: 32rpx;
  padding: 32rpx;
  box-shadow: 0 2rpx 12rpx rgba(0, 0, 0, 0.04);
}

.section-title {
  font-size: 30rpx;
  font-weight: 700;
  color: #0f172a;
  margin-bottom: 24rpx;
  display: block;
}

.comment-item {
  display: flex;
  gap: 16rpx;
  padding: 20rpx 0;
  border-bottom: 1rpx solid #f8fafc;
}

.comment-item:last-child {
  border-bottom: none;
}

.comment-avatar {
  width: 64rpx;
  height: 64rpx;
  border-radius: 50%;
  flex-shrink: 0;
}

.comment-body {
  flex: 1;
  min-width: 0;
}

.comment-author {
  font-size: 26rpx;
  font-weight: 600;
  color: #1e293b;
  display: block;
  margin-bottom: 4rpx;
}

.comment-text {
  font-size: 26rpx;
  color: #475569;
  line-height: 1.6;
  display: block;
  word-break: break-all;
}

.comment-footer {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-top: 8rpx;
}

.comment-time {
  font-size: 22rpx;
  color: #94a3b8;
}

.comment-like {
  font-size: 22rpx;
  color: #94a3b8;
}

/* 评论输入 */
.comment-input-area {
  position: fixed;
  bottom: 0;
  left: 0;
  right: 0;
  padding: 16rpx 32rpx;
  padding-bottom: calc(16rpx + env(safe-area-inset-bottom));
  background: #ffffff;
  border-top: 1rpx solid #f1f5f9;
  z-index: 100;
}

.comment-input-wrap {
  display: flex;
  align-items: center;
  gap: 16rpx;
}

.comment-input {
  flex: 1;
  height: 72rpx;
  padding: 0 24rpx;
  background: #f8fafc;
  border-radius: 36rpx;
  font-size: 26rpx;
  min-width: 0;
}

.comment-send-btn {
  background: #2563eb;
  color: #ffffff;
  padding: 16rpx 32rpx;
  border-radius: 36rpx;
  font-size: 26rpx;
  font-weight: 600;
  flex-shrink: 0;
  white-space: nowrap;
}
