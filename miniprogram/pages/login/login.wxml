<view class="page">
  <!-- 背景装饰 -->
  <view class="bg-decor"></view>

  <!-- Logo区域 -->
  <view class="logo-area">
    <view class="logo-icon">🌐</view>
    <text class="logo-title">浙大城市学院智校通</text>
    <text class="logo-sub">智慧校园 · 一站式服务</text>
  </view>

  <!-- 登录卡片 -->
  <view class="login-card">
    <!-- 标签切换 -->
    <view class="tab-switch">
      <text class="tab-item {{loginType === 'password' ? 'active' : ''}}" bindtap="switchToPassword">密码登录</text>
      <text class="tab-item {{loginType === 'sms' ? 'active' : ''}}" bindtap="switchToSms">验证码登录</text>
    </view>

    <!-- 密码登录表单 -->
    <view class="form-area" wx:if="{{loginType === 'password'}}">
      <view class="form-item">
        <text class="form-label">学号 / 工号</text>
        <view class="input-wrap">
          <text class="input-icon">👤</text>
          <input class="form-input" placeholder="请输入学号或工号" value="{{studentId}}" bindinput="onStudentIdInput" />
        </view>
      </view>
      <view class="form-item">
        <text class="form-label">密码</text>
        <view class="input-wrap">
          <text class="input-icon">🔒</text>
          <input class="form-input" placeholder="请输入密码" password="{{!showPassword}}" value="{{password}}" bindinput="onPasswordInput" />
          <text class="toggle-pwd" bindtap="togglePassword">{{showPassword ? '👁️' : '👁️‍🗨️'}}</text>
        </view>
      </view>
      <view class="form-extra">
        <view class="remember-row">
          <switch checked="{{rememberPwd}}" bindchange="onRememberChange" color="#2563eb" size="mini" />
          <text class="remember-text">记住密码</text>
        </view>
        <text class="forgot-link">忘记密码？</text>
      </view>
    </view>

    <!-- 验证码登录表单 -->
    <view class="form-area" wx:if="{{loginType === 'sms'}}">
      <view class="form-item">
        <text class="form-label">手机号</text>
        <view class="input-wrap">
          <text class="input-icon">📱</text>
          <input class="form-input" type="number" placeholder="请输入绑定手机号" value="{{phone}}" bindinput="onPhoneInput" maxlength="11" />
        </view>
      </view>
      <view class="form-item">
        <text class="form-label">验证码</text>
        <view class="sms-row">
          <view class="input-wrap flex-1">
            <text class="input-icon">🛡️</text>
            <input class="form-input" placeholder="请输入验证码" value="{{smsCode}}" bindinput="onSmsCodeInput" maxlength="6" />
          </view>
          <view class="sms-btn {{countdown > 0 ? 'disabled' : ''}}" bindtap="getSmsCode">
            <text>{{countdown > 0 ? countdown + 's' : '获取验证码'}}</text>
          </view>
        </view>
      </view>
    </view>

    <!-- 登录按钮 -->
    <view class="login-btn" bindtap="onLogin">
      <text class="login-btn-text">登 录</text>
    </view>

    <!-- 注册链接 -->
    <text class="register-link">还没有账号？<text class="link">立即注册</text></text>
  </view>

  <!-- 底部提示 -->
  <text class="bottom-hint">登录即表示同意《用户协议》和《隐私政策》</text>
</view>
