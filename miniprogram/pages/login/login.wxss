.page {
  min-height: 100vh;
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  padding: 60rpx 32rpx 40rpx;
  position: relative;
  overflow: hidden;
  box-sizing: border-box;
}

.bg-decor {
  position: fixed;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
  z-index: 0;
}

.logo-area {
  position: relative;
  z-index: 1;
  text-align: center;
  margin-bottom: 48rpx;
}

.logo-icon {
  width: 96rpx;
  height: 96rpx;
  background: #ffffff;
  border-radius: 28rpx;
  display: flex;
  justify-content: center;
  align-items: center;
  margin: 0 auto 20rpx;
  font-size: 48rpx;
  box-shadow: 0 8rpx 24rpx rgba(0, 0, 0, 0.15);
}

.logo-title {
  font-size: 40rpx;
  font-weight: 700;
  color: #ffffff;
  display: block;
}

.logo-sub {
  font-size: 26rpx;
  color: rgba(255, 255, 255, 0.7);
  display: block;
  margin-top: 8rpx;
}

.login-card {
  position: relative;
  z-index: 1;
  width: 100%;
  background: #ffffff;
  border-radius: 40rpx;
  padding: 40rpx 36rpx;
  box-shadow: 0 16rpx 48rpx rgba(0, 0, 0, 0.15);
  box-sizing: border-box;
}

.tab-switch {
  display: flex;
  gap: 32rpx;
  margin-bottom: 40rpx;
  border-bottom: 1rpx solid #f1f5f9;
}

.tab-item {
  padding-bottom: 20rpx;
  font-size: 30rpx;
  font-weight: 500;
  color: #94a3b8;
  border-bottom: 4rpx solid transparent;
}

.tab-item.active {
  color: #2563eb;
  border-bottom-color: #2563eb;
  font-weight: 600;
}

.form-area {
  margin-bottom: 32rpx;
}

.form-item {
  margin-bottom: 24rpx;
}

.form-label {
  font-size: 26rpx;
  font-weight: 500;
  color: #475569;
  margin-bottom: 12rpx;
  display: block;
}

.input-wrap {
  display: flex;
  align-items: center;
  border: 2rpx solid #e2e8f0;
  border-radius: 20rpx;
  padding: 0 24rpx;
  background: #ffffff;
}

.input-icon {
  font-size: 32rpx;
  margin-right: 12rpx;
  flex-shrink: 0;
}

.form-input {
  flex: 1;
  height: 80rpx;
  font-size: 28rpx;
  min-width: 0;
}

.toggle-pwd {
  font-size: 32rpx;
  padding: 8rpx;
  flex-shrink: 0;
}

.form-extra {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 16rpx;
}

.remember-row {
  display: flex;
  align-items: center;
  gap: 8rpx;
}

.remember-text {
  font-size: 24rpx;
  color: #64748b;
}

.forgot-link {
  font-size: 24rpx;
  color: #2563eb;
  flex-shrink: 0;
}

.sms-row {
  display: flex;
  gap: 16rpx;
  align-items: center;
}

.sms-btn {
  background: #f1f5f9;
  color: #475569;
  padding: 20rpx 24rpx;
  border-radius: 20rpx;
  font-size: 24rpx;
  font-weight: 500;
  white-space: nowrap;
  flex-shrink: 0;
}

.sms-btn.disabled {
  color: #94a3b8;
}

.login-btn {
  background: linear-gradient(135deg, #2563eb, #4338ca);
  text-align: center;
  padding: 28rpx;
  border-radius: 20rpx;
  margin-top: 16rpx;
  box-shadow: 0 8rpx 24rpx rgba(37, 99, 235, 0.3);
}

.login-btn-text {
  color: #ffffff;
  font-size: 32rpx;
  font-weight: 700;
}

.register-link {
  display: block;
  text-align: center;
  font-size: 26rpx;
  color: #64748b;
  margin-top: 32rpx;
}

.link {
  color: #2563eb;
  font-weight: 500;
}

.bottom-hint {
  position: relative;
  z-index: 1;
  text-align: center;
  font-size: 22rpx;
  color: rgba(255, 255, 255, 0.5);
  margin-top: 32rpx;
  padding: 0 16rpx;
}
