.page {
  padding: 24rpx 32rpx;
  background: #f8fafc;
  min-height: 100vh;
}

/* 搜索区域 */
.search-section {
  background: #ffffff;
  border-radius: 32rpx;
  padding: 32rpx;
  margin-bottom: 24rpx;
  border: 1rpx solid #f1f5f9;
}

.search-bar {
  display: flex;
  align-items: center;
  gap: 12rpx;
  margin-bottom: 24rpx;
}

.search-icon {
  font-size: 32rpx;
  flex-shrink: 0;
  position: absolute;
  margin-left: 24rpx;
}

.search-input {
  flex: 1;
  height: 80rpx;
  padding: 0 24rpx 0 64rpx;
  border: 2rpx solid #e2e8f0;
  border-radius: 20rpx;
  font-size: 28rpx;
  box-sizing: border-box;
}

.search-btn {
  background: linear-gradient(135deg, #2563eb, #4338ca);
  color: #ffffff;
  padding: 20rpx 32rpx;
  border-radius: 20rpx;
  font-size: 26rpx;
  font-weight: 700;
  flex-shrink: 0;
  white-space: nowrap;
}

.hot-keywords {
  display: flex;
  flex-wrap: wrap;
  gap: 12rpx;
}

.keyword {
  font-size: 24rpx;
  background: #f1f5f9;
  color: #475569;
  padding: 12rpx 24rpx;
  border-radius: 16rpx;
  white-space: nowrap;
}

/* 搜索结果 */
.results-section {
  margin-top: 24rpx;
}

.results-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 20rpx;
}

.results-title {
  font-size: 32rpx;
  font-weight: 700;
  color: #0f172a;
}

.results-count {
  font-size: 24rpx;
  color: #64748b;
  flex-shrink: 0;
}

.result-card {
  background: #ffffff;
  border-radius: 32rpx;
  padding: 28rpx;
  margin-bottom: 20rpx;
  border: 1rpx solid #f1f5f9;
  box-shadow: 0 2rpx 12rpx rgba(0, 0, 0, 0.04);
  overflow: hidden;
}

.result-header {
  display: flex;
  align-items: center;
  margin-bottom: 16rpx;
}

.result-avatar {
  width: 64rpx;
  height: 64rpx;
  border-radius: 50%;
  margin-right: 12rpx;
  flex-shrink: 0;
}

.result-author-info {
  flex: 1;
  min-width: 0;
}

.result-author {
  font-size: 26rpx;
  font-weight: 700;
  color: #1e293b;
  display: block;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}

.result-time {
  font-size: 22rpx;
  color: #94a3b8;
}

.result-title {
  font-size: 30rpx;
  font-weight: 700;
  color: #0f172a;
  margin-bottom: 12rpx;
  display: block;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}

.result-content {
  font-size: 26rpx;
  color: #475569;
  line-height: 1.6;
  display: block;
  word-break: break-all;
}

.result-stats {
  display: flex;
  gap: 24rpx;
  margin-top: 16rpx;
  flex-wrap: wrap;
}

.result-stats .stat {
  font-size: 22rpx;
  color: #94a3b8;
}

/* 无结果 */
.no-results {
  text-align: center;
  padding: 80rpx 0;
}

.no-icon {
  font-size: 80rpx;
  display: block;
  margin-bottom: 20rpx;
}

.no-title {
  font-size: 36rpx;
  font-weight: 700;
  color: #475569;
  display: block;
  margin-bottom: 12rpx;
}

.no-desc {
  font-size: 26rpx;
  color: #94a3b8;
  display: block;
  margin-bottom: 32rpx;
}

.no-btn {
  display: inline-block;
  background: linear-gradient(135deg, #2563eb, #4338ca);
  color: #ffffff;
  padding: 20rpx 48rpx;
  border-radius: 20rpx;
  font-weight: 700;
  font-size: 28rpx;
}
